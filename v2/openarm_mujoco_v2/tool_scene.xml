Tool-use scene (Phase 3b): a long stick the robot grasps and uses to reach BEYOND its
own workspace. A block sits near the far edge of the table (past the bare gripper's
top-down reach) and the goal is even further out. The robot grasps the stick (weld),
then pushes the block to the far goal with the stick's tip -- a task it cannot do
bare-handed. Reach-extending tool use, classical control.
-->

<mujoco model="openarm_v20_tool">
  <compiler meshdir="assets" angle="radian"/>

  <statistic center="0 0 0.6" extent="1.2" meansize="0.05"/>
  <option timestep="0.002" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.2 0.2 0.2" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.38 0.38 0.4" rgb2="0.3 0.3 0.32"
      markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <model name="arm_pedestal" file="openarm_pedestal.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="tablecam" pos="0.34 -0.14 1.3" xyaxes="1 0 0 0 1 0" fovy="64"/>
    <camera name="frontcam" pos="1.05 -0.14 0.9" xyaxes="0 -1 0 0.3 0 1" fovy="58"/>

    <attach model="arm_pedestal" prefix=""/>

    <!-- Wide table so the far block + goal are well past the bare-arm reach. -->
    <body name="table" pos="0.34 -0.14 0.36">
      <geom name="table_top" type="box" size="0.30 0.26 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1" />
    </body>

    <!-- The stick (280 mm long, along x), grasped at its centre and used as a pusher
         that extends the reach ~0.14 m forward. -->
    <body name="stick" pos="0.22 -0.14 0.414">
      <freejoint />
      <geom name="stick_geom" type="box" size="0.18 0.013 0.014" rgba="0.55 0.35 0.15 1"
            mass="0.06" friction="1 0.01 0.001" contype="1" conaffinity="1" />
    </body>

    <!-- Block to move, just past the gripper's top-down reach (~0.36 m). -->
    <body name="block" pos="0.46 -0.14 0.423">
      <freejoint />
      <geom name="block_geom" type="box" size="0.03 0.03 0.023" rgba="0.2 0.55 0.85 1"
            mass="0.1" friction="0.6 0.01 0.001" contype="1" conaffinity="1" />
    </body>

    <!-- Far goal (out of bare reach; reachable only via the stick's tip). -->
    <body name="goal" pos="0.52 -0.14 0.401">
      <site name="goal_site" type="cylinder" size="0.05 0.001" rgba="0.2 0.8 0.3 0.4"/>
    </body>
  </worldbody>

  <equality>
    <weld name="grasp_right_stick" body1="openarm_right_ee_base_link" body2="stick" active="false" solref="0.02 1"/>
  </equality>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) + stick(18-24) + block(25-31) = 32. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0
            0.22 -0.14 0.414 1 0 0 0
            0.46 -0.14 0.423 1 0 0 0" />
  </keyframe>

</mujoco>
