Bimanual hand-over scene (Phase I): a WIDE table with a bin on the far RIGHT
(only the right arm can reach it) and two cubes — a red one on the LEFT (the left
arm picks it, but can't reach the right bin -> it must hand off to the right arm)
and a green one on the RIGHT (the right arm does that one alone). Both cubes carry
both arms' grasp welds so either arm can hold them.
-->

<mujoco model="openarm_v20_bimanual_handover">
  <compiler meshdir="assets" angle="radian"/>

  <default>
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" />
    </default>
    <default class="collision">
      <geom condim="3" conaffinity="1" priority="1" group="3" solref="0.005 1" friction="1 0.01 0.01" />
    </default>
  </default>

  <statistic center="0.27 0 0.55" extent="1.3" meansize="0.05"/>
  <option timestep="0.002" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.2 0.2 0.2" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.38 0.38 0.4" rgb2="0.3 0.3 0.32"
      markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <mesh name="body_link0"      content_type="model/stl" file="visual/body/body_link0.stl"        scale="0.001 0.001 0.001" />
    <mesh name="body_link0_symp" content_type="model/stl" file="collision/body_link0_symp.stl"    scale="0.001 0.001 0.001" />

    <model name="bimanual" file="openarm_v20_bimanual.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="tablecam" pos="0.28 0.0 1.35" xyaxes="1 0 0 0 1 0" fovy="60"/>
    <camera name="frontcam" pos="1.05 0.0 0.85" xyaxes="0 -1 0 0.3 0 1" fovy="55"/>

    <geom name="openarm_body_link0_visual"    type="mesh" mesh="body_link0"      class="visual"    material="openarm_body_link0_material" />
    <geom name="openarm_body_link0_collision" type="mesh" mesh="body_link0_symp" class="collision" />

    <frame pos="0 0 0.698">
      <attach model="bimanual" prefix=""/>
    </frame>

    <body name="table" pos="0.27 0.0 0.36">
      <geom name="table_top" type="box" size="0.21 0.42 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1" />
    </body>

    <!-- Red cube on the LEFT (+y): the left arm picks it, then hands it over. -->
    <body name="box_red" pos="0.25 0.30 0.425"><freejoint/>
      <geom name="box_red_geom" type="box" size="0.025 0.025 0.025" rgba="0.85 0.15 0.15 1" mass="0.05" friction="2.5 0.1 0.01" contype="1" conaffinity="1"/></body>

    <!-- Green cube on the RIGHT (-y): the right arm handles it alone. -->
    <body name="box_green" pos="0.20 -0.16 0.425"><freejoint/>
      <geom name="box_green_geom" type="box" size="0.025 0.025 0.025" rgba="0.15 0.7 0.2 1" mass="0.05" friction="2.5 0.1 0.01" contype="1" conaffinity="1"/></body>

    <!-- Bin on the far RIGHT (-y): only the right arm can reach it. -->
    <body name="bin" pos="0.30 -0.34 0.40">
      <geom name="bin_floor" type="box" size="0.07 0.07 0.01" pos="0 0 0.01" rgba="0.4 0.4 0.45 1" contype="1" conaffinity="1"/>
      <geom name="bin_n" type="box" size="0.07 0.008 0.035" pos="0 0.07 0.035" rgba="0.4 0.4 0.45 1" contype="1" conaffinity="1"/>
      <geom name="bin_s" type="box" size="0.07 0.008 0.035" pos="0 -0.07 0.035" rgba="0.4 0.4 0.45 1" contype="1" conaffinity="1"/>
      <geom name="bin_e" type="box" size="0.008 0.07 0.035" pos="0.07 0 0.035" rgba="0.4 0.4 0.45 1" contype="1" conaffinity="1"/>
      <geom name="bin_w" type="box" size="0.008 0.07 0.035" pos="-0.07 0 0.035" rgba="0.4 0.4 0.45 1" contype="1" conaffinity="1"/>
    </body>
  </worldbody>

  <equality>
    <weld name="grasp_right_red"   body1="openarm_right_ee_base_link" body2="box_red"   active="false" solref="0.02 1"/>
    <weld name="grasp_left_red"    body1="openarm_left_ee_base_link"  body2="box_red"   active="false" solref="0.02 1"/>
    <weld name="grasp_right_green" body1="openarm_right_ee_base_link" body2="box_green" active="false" solref="0.02 1"/>
    <weld name="grasp_left_green"  body1="openarm_left_ee_base_link"  body2="box_green" active="false" solref="0.02 1"/>
  </equality>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) + 2 boxes x 7 (18-31) = 32. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0
            0.25 0.30 0.425 1 0 0 0
            0.20 -0.16 0.425 1 0 0 0" />
  </keyframe>

</mujoco>
