Move-a-puck scene (Phase 3a): a low puck on the table and two goal regions.
The puck can be pushed to a goal with the closed gripper as a pusher (the
non-prehensile skill this scene was built for, re-planning the push direction
as the puck drifts) or grasped and placed -- a small target for either style
of manipulation.
-->

<mujoco model="openarm_v20_move_puck">
  <compiler meshdir="assets" angle="radian"/>

  <statistic center="0 0 0.6" extent="1.1" meansize="0.05"/>
  <option timestep="0.002" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.2 0.2 0.2" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.38 0.38 0.4" rgb2="0.3 0.3 0.32"
      markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <model name="arm_pedestal" file="openarm_pedestal.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="tablecam" pos="0.26 -0.18 1.15" xyaxes="1 0 0 0 1 0" fovy="60"/>
    <camera name="frontcam" pos="0.95 -0.18 0.85" xyaxes="0 -1 0 0.3 0 1" fovy="55"/>

    <attach model="arm_pedestal" prefix=""/>

    <!-- Table: top at z=0.40. -->
    <body name="table" pos="0.27 -0.18 0.36">
      <geom name="table_top" type="box" size="0.22 0.26 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1" />
    </body>

    <!-- A low, slippery puck (70 x 70 x 44 mm) the gripper pushes (does not grasp). -->
    <body name="puck" pos="0.20 -0.14 0.422">
      <freejoint />
      <geom name="puck_geom" type="box" size="0.035 0.035 0.022" rgba="0.85 0.4 0.1 1"
            mass="0.12" friction="0.9 0.01 0.001" contype="1" conaffinity="1" />
    </body>

    <!-- Goal regions (visual markers, non-colliding). -->
    <body name="goal_a" pos="0.33 -0.30 0.401">
      <site name="goal_a_site" type="cylinder" size="0.05 0.001" rgba="0.2 0.8 0.3 0.4"/>
    </body>
    <body name="goal_b" pos="0.30 -0.02 0.401">
      <site name="goal_b_site" type="cylinder" size="0.05 0.001" rgba="0.3 0.5 0.9 0.4"/>
    </body>
  </worldbody>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) + puck(18-24) = 25. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0
            0.20 -0.14 0.422 1 0 0 0" />
  </keyframe>

</mujoco>
