Cloth-folding scene (Phase 3c): a deformable square cloth (a MuJoCo flex grid) lying
on the table. The robot grasps a corner (a weld to the corner vertex body), lifts it,
and carries it across to the opposite edge to fold the cloth in half. Deformable
manipulation -- the frontier classical control alone can't fully cover; the scripted
fold here also generates demonstrations for an imitation-learned policy.
-->

<mujoco model="openarm_v20_cloth">
  <compiler meshdir="assets" angle="radian"/>

  <statistic center="0 0 0.6" extent="1.1" meansize="0.05"/>
  <option timestep="0.002" solver="CG" iterations="30" tolerance="1e-6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.2 0.2 0.2" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.38 0.38 0.4" rgb2="0.3 0.3 0.32"
      markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="cloth_mat" rgba="0.2 0.45 0.8 1"/>

    <model name="arm_pedestal" file="openarm_pedestal.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="tablecam" pos="0.26 -0.14 1.1" xyaxes="1 0 0 0 1 0" fovy="58"/>
    <camera name="frontcam" pos="0.95 -0.14 0.85" xyaxes="0 -1 0 0.3 0 1" fovy="55"/>

    <attach model="arm_pedestal" prefix=""/>

    <!-- Table: top at z=0.40. -->
    <body name="table" pos="0.26 -0.14 0.36">
      <geom name="table_top" type="box" size="0.24 0.24 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1" />
    </body>

    <!-- Deformable cloth: a 5x5 flex grid (~0.20 m square) just above the table. Each
         grid vertex is a body (cloth_0 .. cloth_24); corners are 0, 4, 20, 24. -->
    <flexcomp name="cloth" type="grid" count="9 9 1" spacing="0.0185 0.0185 0.0185"
              pos="0.25 -0.13 0.404" dim="2" mass="0.08" radius="0.0045">
      <edge equality="true" solref="0.006 1"/>
      <contact condim="3" solref="0.008 1" friction="1.5 0.05 0.01" selfcollide="narrow"/>
    </flexcomp>
  </worldbody>

  <equality>
    <!-- Grasp welds for the four corners of the 9x9 grid (0, 8, 72, 80). -->
    <weld name="grasp_right_0"  body1="openarm_right_ee_base_link" body2="cloth_0"  active="false" solref="0.02 1"/>
    <weld name="grasp_right_8"  body1="openarm_right_ee_base_link" body2="cloth_8"  active="false" solref="0.02 1"/>
    <weld name="grasp_right_72" body1="openarm_right_ee_base_link" body2="cloth_72" active="false" solref="0.02 1"/>
    <weld name="grasp_right_80" body1="openarm_right_ee_base_link" body2="cloth_80" active="false" solref="0.02 1"/>
  </equality>

</mujoco>
