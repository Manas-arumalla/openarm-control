Bimanual airborne catching: a ball is thrown through the air toward EITHER side
of the robot. Two RGB-D cameras observe it; the system estimates the trajectory,
solves an interception for BOTH arms, picks the arm that can reach it best, and
catches it collision-free (the idle arm stays in a safe ready pose). Cameras aim
at the centre so throws toward the left or right arm are both in view.
-->

<mujoco model="openarm_v20_catch_bimanual">
  <compiler meshdir="assets" angle="radian"/>

  <default>
    <default class="visual"><geom contype="0" conaffinity="0" group="2"/></default>
    <default class="collision">
      <geom condim="3" conaffinity="1" priority="1" group="3" solref="0.005 1" friction="1 0.01 0.01"/>
    </default>
  </default>

  <statistic center="0.3 0 0.9" extent="1.5" meansize="0.05"/>
  <option timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-12" offwidth="1280" offheight="960"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <mesh name="body_link0"      content_type="model/stl" file="visual/body/body_link0.stl"     scale="0.001 0.001 0.001"/>
    <mesh name="body_link0_symp" content_type="model/stl" file="collision/body_link0_symp.stl" scale="0.001 0.001 0.001"/>
    <model name="bimanual" file="openarm_v20_bimanual.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <geom name="openarm_body_link0_visual"    type="mesh" mesh="body_link0"      class="visual"    material="openarm_body_link0_material"/>
    <geom name="openarm_body_link0_collision" type="mesh" mesh="body_link0_symp" class="collision"/>
    <frame pos="0 0 0.698"><attach model="bimanual" prefix=""/></frame>

    <!-- Two RGB-D cameras (opposite sides) aimed at the centre, so throws toward
         either arm stay in view across the whole ballistic arc. -->
    <camera name="ballcam0" pos="1.05 -1.55 1.25" fovy="62"
            xyaxes="0.9603 0.2788 -0.0000 -0.0343 0.1181 0.9924"/>
    <camera name="ballcam1" pos="1.05 1.55 1.25" fovy="62"
            xyaxes="-0.9603 0.2788 0.0000 -0.0343 -0.1181 0.9924"/>
    <!-- Viewing camera for the demo/GIF. -->
    <camera name="catchcam" pos="1.7 0 1.5" xyaxes="0 1 0 -0.6 0 0.8"/>

    <body name="ball" pos="1.05 -0.25 0.95">
      <freejoint/>
      <geom name="ball_geom" type="sphere" size="0.035" rgba="0.95 0.55 0.1 1"
            mass="0.05" friction="1 0.05 0.01" contype="1" conaffinity="1"/>
    </body>
  </worldbody>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) + ball(18-24) = 25. Both arms in a
         mirrored catch-ready pose (grippers OPEN): left = MIRROR_R2L * right, so
         the left grasp point sits at (~0.40, +0.22, 0.95) and the right at
         (~0.40, -0.22, 0.95). Left gripper opens at +0.7854, right at -0.7854. -->
    <key name="ready"
      qpos="-1.63955 -0.67234 0.68604 1.32130 0.69509 -0.33258 -0.43927 0.7854 0.7854
            1.63955 0.67234 -0.68604 1.32130 -0.69509 0.33258 0.43927 -0.7854 -0.7854
            1.05 -0.25 0.95 1 0 0 0"/>
  </keyframe>

  <equality>
    <weld name="grasp_right_ball" body1="openarm_right_ee_base_link" body2="ball" active="false" solref="0.02 1"/>
    <weld name="grasp_left_ball"  body1="openarm_left_ee_base_link"  body2="ball" active="false" solref="0.02 1"/>
  </equality>

</mujoco>
