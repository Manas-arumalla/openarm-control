Webcam imitation with manipulation: both arms on the pedestal, a table with three
colored blocks in front of the right arm, and weld constraints so a closed hand
grasps a block (and an open hand releases it). The teleop controller mirrors the
user's arm AND hand, so the user can reach out, close their hand to pick a block
up, move it, and open their hand to drop it.
-->

<mujoco model="openarm_v20_teleop_pick">
  <compiler meshdir="assets" angle="radian"/>

  <default>
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" />
    </default>
    <default class="collision">
      <geom condim="3" conaffinity="1" priority="1" group="3" solref="0.005 1" friction="1 0.01 0.01" />
    </default>
  </default>

  <statistic center="0 0 0.85" extent="1.3" meansize="0.05"/>
  <option timestep="0.002" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-12"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <mesh name="body_link0"      content_type="model/stl" file="visual/body/body_link0.stl"        scale="0.001 0.001 0.001" />
    <mesh name="body_link0_symp" content_type="model/stl" file="collision/body_link0_symp.stl"    scale="0.001 0.001 0.001" />

    <model name="bimanual" file="openarm_v20_bimanual.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="frontcam" pos="1.7 0 1.15" xyaxes="0 -1 0 0 0 1" fovy="50"/>

    <geom name="openarm_body_link0_visual"    type="mesh" mesh="body_link0"      class="visual"    material="openarm_body_link0_material" />
    <geom name="openarm_body_link0_collision" type="mesh" mesh="body_link0_symp" class="collision" />

    <frame pos="0 0 0.698">
      <attach model="bimanual" prefix=""/>
    </frame>

    <!-- Table in front of and BELOW the resting gripper (whose lowest point is
         z~0.51), so it never collides at the ready pose; top at z=0.42. You reach
         down-forward to put the gripper on a block. -->
    <body name="table" pos="0.30 -0.22 0.38">
      <geom name="table_top" type="box" size="0.14 0.15 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1" />
    </body>

    <!-- Three colored blocks (40x40x60 mm), spread in y at x=0.30, on the table
         top (z = 0.42 + 0.03), spaced 0.08 m so the open gripper clears neighbours. -->
    <body name="block_red" pos="0.30 -0.30 0.45">
      <freejoint />
      <geom name="block_red_geom" type="box" size="0.02 0.02 0.03" rgba="0.9 0.2 0.2 1"
            mass="0.05" friction="2.5 0.1 0.01" contype="1" conaffinity="1" />
    </body>
    <body name="block_green" pos="0.30 -0.22 0.45">
      <freejoint />
      <geom name="block_green_geom" type="box" size="0.02 0.02 0.03" rgba="0.2 0.8 0.2 1"
            mass="0.05" friction="2.5 0.1 0.01" contype="1" conaffinity="1" />
    </body>
    <body name="block_blue" pos="0.30 -0.14 0.45">
      <freejoint />
      <geom name="block_blue_geom" type="box" size="0.02 0.02 0.03" rgba="0.2 0.3 0.9 1"
            mass="0.05" friction="2.5 0.1 0.01" contype="1" conaffinity="1" />
    </body>

    <!-- Grasp-point marker: a translucent yellow sphere the controller moves to
         the point between the gripper pads each frame, so you can see exactly
         where a grab will happen and guide your arm onto a block. -->
    <body name="grasp_marker" mocap="true" pos="0.2 -0.2 0.6">
      <geom type="sphere" size="0.02" rgba="1 0.9 0.1 0.55" contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <equality>
    <weld name="grasp_right_red"   body1="openarm_right_ee_base_link" body2="block_red"   active="false" solref="0.02 1"/>
    <weld name="grasp_right_green" body1="openarm_right_ee_base_link" body2="block_green" active="false" solref="0.02 1"/>
    <weld name="grasp_right_blue"  body1="openarm_right_ee_base_link" body2="block_blue"  active="false" solref="0.02 1"/>
    <weld name="grasp_left_red"    body1="openarm_left_ee_base_link"  body2="block_red"   active="false" solref="0.02 1"/>
    <weld name="grasp_left_green"  body1="openarm_left_ee_base_link"  body2="block_green" active="false" solref="0.02 1"/>
    <weld name="grasp_left_blue"   body1="openarm_left_ee_base_link"  body2="block_blue"  active="false" solref="0.02 1"/>
  </equality>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) + 3 blocks x 7 (18-38) = 39. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0
            0.30 -0.30 0.45 1 0 0 0
            0.30 -0.22 0.45 1 0 0 0
            0.30 -0.14 0.45 1 0 0 0" />
  </keyframe>

</mujoco>
