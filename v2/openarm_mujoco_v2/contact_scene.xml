Contact / compliance scene (extension phase F2): a compliant foam-like PAD fixed
on the table for the OpenArm to press on. The pad uses a soft contact (slow solref
time constant) so the interaction force rises smoothly rather than as a rigid
impact -- the right setting to demonstrate and test admittance control (the arm
yields on contact instead of pushing rigidly through). Used by `openarm admittance`
and the F2 test; the contact-rich skills are built on this controller in S3.
-->
<mujoco model="openarm_v20_contact">
  <compiler meshdir="assets" angle="radian"/>

  <statistic center="0.27 0 0.55" extent="1.1" meansize="0.05"/>
  <option timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-20"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.55 0.55 0.58" rgb2="0.2 0.2 0.2" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.38 0.38 0.4" rgb2="0.3 0.3 0.32"
      markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <model name="arm_pedestal" file="openarm_pedestal.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <camera name="tablecam" pos="0.27 0.0 1.15" xyaxes="1 0 0 0 1 0" fovy="55"/>
    <camera name="frontcam" pos="0.95 -0.10 0.85" xyaxes="0 -1 0 0.3 0 1" fovy="50"/>

    <attach model="arm_pedestal" prefix=""/>

    <!-- Table: top at z=0.40. -->
    <body name="table" pos="0.27 -0.02 0.36">
      <geom name="table_top" type="box" size="0.22 0.30 0.04" rgba="0.82 0.71 0.55 1"
            friction="1 0.005 0.0001" contype="1" conaffinity="1"/>
    </body>

    <!-- Compliant pad (soft contact): top at z = 0.40 + 0.03 + 0.03 = 0.46, placed
         within the right arm's straight-down workspace. The slow solref time
         constant makes the contact force rise smoothly, so the arm can press on it
         and the admittance controller can yield gracefully. -->
    <body name="pad" pos="0.22 -0.20 0.40">
      <!-- priority 2 outranks the arm geoms' collision class (priority 1), so the
           pad's soft solref governs finger-pad contacts -- MuJoCo gives all contact
           parameters to the higher-priority geom, and without this the fingers'
           rigid solref (0.005) silently wins and the pad's softness is inert. -->
      <geom name="pad_geom" type="box" size="0.06 0.06 0.03" pos="0 0 0.03"
            rgba="0.25 0.6 0.35 1" contype="1" conaffinity="1" priority="2"
            solref="0.05 1" solimp="0.7 0.9 0.02" friction="1 0.01 0.01"/>
    </body>
  </worldbody>

  <keyframe>
    <!-- nq = left arm(0-8) + right arm(9-17) = 18. Both arms raised and clear. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0"/>
  </keyframe>

</mujoco>
