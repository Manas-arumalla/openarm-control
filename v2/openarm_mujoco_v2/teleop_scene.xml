Clean scene for webcam human-arm imitation (teleoperation): both arms on the
pedestal, no clutter, a front-facing camera, and a neutral ready pose. The
teleop controller drives the arm(s) to mirror a human arm seen by a webcam (or a
synthetic pose source in headless tests).
-->

<mujoco model="openarm_v20_teleop">
  <compiler meshdir="assets" angle="radian"/>

  <statistic center="0 0 0.9" extent="1.3" meansize="0.05"/>
  <option timestep="0.002" />

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-12"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <model name="arm_pedestal" file="openarm_pedestal.xml"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Camera looking at the arms head-on (like a person standing in front). -->
    <camera name="frontcam" pos="1.7 0 1.15" xyaxes="0 -1 0 0 0 1" fovy="48"/>

    <attach model="arm_pedestal" prefix=""/>
  </worldbody>

  <keyframe>
    <!-- nq = left arm (0-8) + right arm (9-17) = 18; both in a neutral ready pose. -->
    <key name="ready"
      qpos="0.720369 -2.27095 -0.290977 1.90389 -1.23759 -0.785149 -0.558776 0 0
            -0.720369 2.27095 0.290977 1.90389 1.23759 0.785149 0.558776 0 0" />
  </keyframe>

</mujoco>
